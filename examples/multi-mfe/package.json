{
  "name": "@esmap-examples/multi-mfe",
  "version": "0.0.1",
  "private": true,
  "description": "Working multi-MFE demo with real browser routing and dynamic imports",
  "type": "module",
  "scripts": {
    "build:apps": "pnpm build:nav && pnpm build:home && pnpm build:settings && pnpm build:react-dashboard",
    "build:nav": "vite build --config apps/app-nav/vite.config.ts",
    "build:home": "vite build --config apps/app-home/vite.config.ts",
    "build:settings": "vite build --config apps/app-settings/vite.config.ts",
    "build:react-dashboard": "vite build --config apps/app-react-dashboard/vite.config.ts",
    "dev": "vite --config host/vite.config.ts",
    "preview": "pnpm build:apps && pnpm dev",
    "build": "echo 'use pnpm preview to run'",
    "test": "echo 'no unit tests — this is an integration demo'"
  },
  "dependencies": {
    "@esmap/core": "workspace:*",
    "@esmap/runtime": "workspace:*",
    "@esmap/shared": "workspace:*",
    "@esmap/devtools": "workspace:*",
    "@esmap/monitor": "workspace:*",
    "@esmap/communication": "workspace:*",
    "@esmap/sandbox": "workspace:*",
    "@esmap/guard": "workspace:*",
    "@esmap/vite-plugin": "workspace:*",
    "@esmap/react": "workspace:*",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vite": "^6.3.0"
  }
}
