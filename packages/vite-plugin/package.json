{
  "name": "@esmap/vite-plugin",
  "version": "0.0.1",
  "description": "Vite plugin for MFE manifest generation and ESM externals configuration",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@esmap/guard": "workspace:*",
    "@esmap/shared": "workspace:*"
  },
  "peerDependencies": {
    "vite": "^5.0.0 || ^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "rollup": "^4.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vite": "^6.3.0",
    "vitest": "^4.0.18"
  },
  "license": "MIT",
  "sideEffects": false
}
