{
  "name": "@esmap/vue",
  "version": "0.0.1",
  "description": "Vue 3 adapter for esmap — lifecycle wrapper for Vue applications",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@esmap/shared": "workspace:*"
  },
  "peerDependencies": {
    "vue": ">=3.3.0"
  },
  "devDependencies": {
    "jsdom": "^26.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^4.0.18",
    "vue": "^3.5.0"
  },
  "license": "MIT",
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
