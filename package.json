{
  "private": true,
  "type": "module",
  "name": "esmap",
  "description": "Import Map all-in-one framework for micro-frontends",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/retemper/esmap"
  },
  "bugs": "https://github.com/retemper/esmap/issues",
  "homepage": "https://github.com/retemper/esmap#readme",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "keywords": [
    "micro-frontends",
    "import-map",
    "mfe",
    "module-federation",
    "esm",
    "micro-frontend-framework"
  ],
  "scripts": {
    "build": "turbo build",
    "test": "turbo test",
    "type-check": "turbo type-check",
    "lint": "turbo lint",
    "dev": "turbo dev",
    "e2e": "playwright test",
    "docs:dev": "pnpm --filter @esmap/docs dev",
    "docs:build": "pnpm --filter @esmap/docs build",
    "docs:preview": "pnpm --filter @esmap/docs preview",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^10.1.0",
    "prettier": "^3.4.0",
    "turbo": "^2.3.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.57.1"
  },
  "packageManager": "pnpm@10.22.0"
}
